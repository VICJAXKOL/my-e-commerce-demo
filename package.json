{
  "name": "my-react-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:dev": "node -e \"const fs=require('fs');const lock='.next/dev/lock';try{fs.rmSync(lock,{force:true});console.log('Removed '+lock);}catch{console.log('No lock file to remove.');}\"",
    "clean:cache": "node -e \"const fs=require('fs');const targets=['.next/cache/webpack','.next/dev/cache'];for(const t of targets){try{fs.rmSync(t,{recursive:true,force:true});console.log('Removed '+t);}catch{}}\"",
    "dev": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --turbopack --disable-source-maps",
    "dev:webpack": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --webpack --disable-source-maps",
    "dev:turbo": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev --turbopack --disable-source-maps",
    "build": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next build",
    "start": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next start",
    "postinstall": "prisma generate",
    "lint": "eslint"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "next": "16.1.6",
    "prisma": "^6.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
