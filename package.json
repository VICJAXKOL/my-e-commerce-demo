{
  "name": "my-react-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:dev": "node -e \"const fs=require('fs');const lock='.next/dev/lock';try{fs.rmSync(lock,{force:true});console.log('Removed '+lock);}catch{console.log('No lock file to remove.');}\"",
    "dev": "node --max-old-space-size=12288 ./node_modules/next/dist/bin/next dev --webpack",
    "dev:turbo": "node --max-old-space-size=12288 ./node_modules/next/dist/bin/next dev --turbopack",
    "build": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next build",
    "start": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "next": "16.1.6",
    "prisma": "^6.19.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
